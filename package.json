{
  "name": "root",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "storybook": "pnpm --filter storybook-base storybook",
    "prepare": "husky",
    "web": "pnpm --filter web",
    "ui": "pnpm --filter ui",
    "api": "pnpm --filter api",
    "db": "pnpm --filter db",
    "i18n:generate": "pnpm i18n:extract && pnpm i18n:types",
    "i18n:extract": "pnpm exec i18next-cli extract --quiet",
    "i18n:lint": "pnpm exec i18next-cli lint",
    "i18n:status": "pnpm exec i18next-cli status",
    "i18n:sync": "pnpm exec i18next-cli sync",
    "i18n:types": "pnpm exec i18next-cli types",
    "i18n:validate": "pnpm exec i18next-cli extract --ci --dry-run --quiet && pnpm i18n:types && pnpm i18n:status && pnpm i18n:lint",
    "lint:types": "pnpm -r exec tsgo --noEmit",
    "ai": "pnpm i18n:generate && pnpm i18n:validate && pnpm lint && pnpm lint:types && pnpm fallow dead-code --quiet && pnpm fallow dupes --quiet && pnpm fmt",
    "lint": "pnpm oxlint",
    "lint:fix": "pnpm oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@storybook/react-vite": "10.2.8"
  },
  "devDependencies": {
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/bun": "^1.3.14",
    "@types/react": "19.2.14",
    "@typescript/native-preview": "catalog:",
    "fallow": "^2.74.0",
    "husky": "^9.1.7",
    "i18next-cli": "^1.56.12",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "pnpm lint"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
